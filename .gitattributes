/mvnw text eol=lf
*.cmd text eol=crlf

# Define project line ending normalization

# Shell scripts and unix-style files should use LF
*.sh text eol=lf
mvnw text eol=lf

# Windows batch files should use CRLF
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Source files: keep LF
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf

# Binary files (don't attempt to normalize)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.jar binary

